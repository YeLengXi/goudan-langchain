# 智谱AI API 配置
ZHIPUAI_API_KEY=9b34093dde244696b6baaf86b84816b5.Zwsy7pZ3O5TuULhN

# 模型选择
# glm-4-flash: 最快最便宜 (推荐)
# glm-4-air: 平衡性能
# glm-4-plus: 最强能力
ZHIPUAI_MODEL=glm-4-flash

# API 基础URL
ZHIPUAI_BASE_URL=https://open.bigmodel.cn/api/paas/v4/

# 工作目录
WORKSPACE_DIR=./workspace
TASKS_DIR=./tasks
LOGS_DIR=./logs

# 日志级别
LOG_LEVEL=info

# ============================================
# 邮件通知配置（可选）
# ============================================

# 邮箱服务商 (qq, 163, gmail, outlook, hotmail 等)
EMAIL_SERVICE=qq

# 发件邮箱地址
EMAIL_USER=your@email.com

# 邮箱授权码（不是登录密码！）
# QQ 邮箱获取方式: 设置 → 账户 → POP3/SMTP 服务 → 生成授权码
EMAIL_PASS=your_authorization_code

# 收件邮箱地址（可以和发件邮箱相同）
EMAIL_TO=your@email.com
